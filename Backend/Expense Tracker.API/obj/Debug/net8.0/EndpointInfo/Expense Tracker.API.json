        "requestBody": {
          "content": {
            "application/json-patch+json": {
              "schema": {
                "$ref": "#/components/schemas/ExtractRequest"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExtractRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ExtractRequest"
              }
            },
            "application/*+json": {
              "schema": {
